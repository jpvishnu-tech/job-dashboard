# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/job-dashboard?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Firebase (server-side token verification, no Admin SDK) ───
# Firebase Console → Project Settings → Web API key
FIREBASE_API_KEY=AIzaSy...

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend URL (used in email links) ────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email / SMTP ──────────────────────────────────────────────
# Leave SMTP_HOST blank to disable all emails (useful for tests).
#
# Gmail setup (recommended for development):
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to myaccount.google.com → Security → App Passwords
#   3. Create a new App Password (select "Mail" + "Windows Computer")
#   4. Paste the 16-character code below — spaces are stripped automatically
#
# SendGrid (recommended for production):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=<your SendGrid API key>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM="JobHub" <your@gmail.com>

# Admin notification recipients (comma-separated)
# Used as a fallback when no admin users are in the database yet.
ADMIN_EMAIL=admin@yourdomain.com

# Set to true to send a security alert email on every sign-in.
# Keep false in development to avoid inbox noise.
SEND_LOGIN_ALERTS=false
